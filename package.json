{
  "name": "detab",
  "version": "1.0.0",
  "scripts": {
    "build": "vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "watch": "vite build --watch",
    "watch:firefox": "BROWSER=firefox vite build --watch",
    "version": "node -e \"['manifest.json','manifest.firefox.json'].forEach(f=>{const m=JSON.parse(require('fs').readFileSync(f));m.version=require('./package.json').version;require('fs').writeFileSync(f,JSON.stringify(m,null,2)+'\\n')})\" && git add manifest.json manifest.firefox.json",
    "format": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,html}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yamanidev/detab.git"
  },
  "keywords": [],
  "author": "Mohamed Yamani (yamanidev)",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/yamanidev/detab/issues"
  },
  "homepage": "https://github.com/yamanidev/detab#readme",
  "description": "",
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
