{
  "manifest_version": 3,
  "name": "Detab",
  "version": "1.0.0",
  "description": "Archive all open tabs into a Markdown file in one click.",
  "permissions": ["tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Detab — Archive your tabs",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "detab@yamanidev",
      "strict_min_version": "109.0"
    }
  }
}
